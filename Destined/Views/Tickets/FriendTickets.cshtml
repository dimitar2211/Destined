@model IEnumerable<Destined.Models.Ticket>

@{
    ViewData["Title"] = "Приятелски Билети";
    ViewData["FullWidth"] = true;
    var friendName = ViewBag.FriendName as string;
    var message = ViewBag.Message as string;
}

@Html.AntiForgeryToken()

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 100px 20px 40px 20px;">
        <div class="ticket-wrapper">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-controller="Friends" asp-action="Index" class="btn-back-glass">⬅ Назад към приятели</a>
            </div>

            <h1 class="page-title">Билетите на <span class="gradient-text">@friendName</span></h1>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert alert-warning text-center" style="background: rgba(255,193,7,0.2); color: #fff; border: 1px solid rgba(255,193,7,0.5);">
                    @message
                </div>
            }
            else if (!Model.Any())
            {
                <div class="no-tickets-card">
                    <p>Този потребител няма билети, които да сподели с теб.</p>
                </div>
            }
            else
            {
                <div id="ticket-list">
                    @foreach (var ticket in Model)
                    {
                        <div class="real-ticket" data-id="@ticket.Id">
                            <div class="ticket-left" style="background:@ticket.LeftColor;">
                                @{
                                    string fromVal = ticket.From ?? "";
                                    string shortFrom = fromVal.Length > 10 ? fromVal.Substring(0, 10) + "…" : fromVal;
                                    string shortTo = ticket.To.Length > 10 ? ticket.To.Substring(0, 10) + "…" : ticket.To;
                                    string textColor = string.IsNullOrEmpty(ticket.TextColor) ? "#000000" : ticket.TextColor;
                                }
                                @if (!string.IsNullOrEmpty(ticket.From))
                                {
                                    <h2 style="color:@textColor">@shortFrom ➔ @shortTo</h2>
                                }
                                else
                                {
                                    <h2 style="color:@textColor">@shortTo</h2>
                                }
                                <p style="color:@textColor"><strong>Дата и час:</strong> @ticket.DepartureTime.ToString("dd.MM.yyyy HH:mm")</p>
                                <p style="color:@textColor"><strong>Пътници:</strong> @ticket.NumberOfPassengers</p>
                                @if (!string.IsNullOrEmpty(ticket.Country))
                                {
                                    <p style="color:@textColor"><strong>Държава:</strong> @ticket.Country</p>
                                }
                            </div>

                            <div class="ticket-center-wrapper">
                                <div class="ticket-center">
                                    <div class="perforation"></div>
                                </div>
                            </div>

                            <div class="ticket-right" style="background:@ticket.RightColor;">
                                <div class="barcode"></div>
                                <div class="actions mt-auto">
                                    <a asp-controller="Journal" asp-action="Page" asp-route-ticketId="@ticket.Id" asp-route-page="1" asp-route-readOnly="true" class="btn btn-journal" title="Дневник">Дневник</a>
                                    @if (ticket.IsPublic)
                                    {
                                        <a asp-controller="Comments" asp-action="Ticket" asp-route-ticketId="@ticket.Id" class="btn btn-comments" title="Коментари">Коментари</a>
                                    }

                                    @{
                                        var likedTicketIds = ViewData["LikedTicketIds"] as List<int> ?? new List<int>();
                                        bool isLiked = likedTicketIds.Contains(ticket.Id);
                                    }
                                    <button type="button" 
                                            class="btn-like @(isLiked ? "liked" : "")" 
                                            onclick="toggleLike(this, @ticket.Id)"
                                            title="@(isLiked ? "Unlike" : "Like")">
                                        <svg viewBox="0 0 24 24" class="heart-icon">
                                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="toast-glass">
    <span id="toastMessage"></span>
</div>

<style>
    .ticket-wrapper { position: relative; max-width: 900px; margin: 0 auto; color: white; }
    .page-title { font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 2rem; }
    .gradient-text { background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .no-tickets-card { text-align: center; padding: 50px; color: #cbd5e1; font-size: 1.2rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 2px dashed rgba(255,255,255,0.2); }

    .real-ticket {
        display: flex; background: linear-gradient(145deg, #fafafa, #e6e6e6); border-radius: 15px; margin-bottom: 30px;
        filter: drop-shadow(0 10px 10px rgba(0,0,0,0.15));
        overflow: hidden; cursor: default; transition: transform 0.3s ease, filter 0.3s ease; border: 1.5px solid #bbb; position: relative; font-weight: 600; user-select: none; color: #333;
        
        -webkit-mask: 
            radial-gradient(circle at center top, transparent 15px, black 15.5px) top center / 100% 51% no-repeat,
            radial-gradient(circle at center bottom, transparent 15px, black 15.5px) bottom center / 100% 51% no-repeat;
        mask: 
            radial-gradient(circle at center top, transparent 15px, black 15.5px) top center / 100% 51% no-repeat,
            radial-gradient(circle at center bottom, transparent 15px, black 15.5px) bottom center / 100% 51% no-repeat;
    }
    .real-ticket:hover { transform: translateY(-6px); filter: drop-shadow(0 18px 20px rgba(0,0,0,0.3)); border-color: #4caf50; }
    .ticket-left, .ticket-right { padding: 25px 30px; flex: 1; position: relative; z-index: 10; }
    .ticket-left { background: #e0f2f1; border-right: 1.5px dashed #999; display: flex; flex-direction: column; justify-content: center; }
    .ticket-left h2 { font-size: 2rem; margin-bottom: 12px; color: #00796b; text-shadow: 0 1px 1px #a0d4cf; letter-spacing: 1.2px; }
    .ticket-left p { font-size: 1.1rem; color: #004d40; margin: 6px 0; }
    
    .ticket-center-wrapper { width: 30px; display: flex; flex-direction: column; justify-content: center; margin: 0; background: transparent; }
    .ticket-center { width: 30px; height: 100%; background: repeating-linear-gradient( to bottom, transparent, transparent 8px, #999 8px, #999 10px ); position: relative; }
    
    .ticket-right { background: #fff; box-shadow: inset 0 4px 10px rgba(0,0,0,0.1); display: flex; flex-direction: column; justify-content: space-between; border-left: 1.5px dashed #999; }
    .barcode { width: 100%; height: 60px; background: repeating-linear-gradient( to right, #000, #000 3px, #fff 3px, #fff 6px, #000 6px, #000 9px, #fff 9px, #fff 12px, #000 12px, #000 15px, #fff 15px, #fff 18px ); border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.25); margin-bottom: 18px; }
    .serial-number { font-size: 0.9rem; font-family: 'Courier New', Courier, monospace; color: #666; margin-bottom: 15px; text-align: center; }

    .actions { display: flex; justify-content: space-around; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
    .btn { 
        padding: 8px 16px; 
        border-radius: 20px; 
        text-decoration: none; 
        font-size: 0.9rem; 
        font-weight: 600; 
        cursor: pointer; 
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        border: 1px solid rgba(0,0,0,0.1); 
        color: #333; 
        display: inline-block; 
        text-align: center;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .btn-back-glass { 
        padding: 10px 24px; border-radius: 50px; text-decoration: none; font-weight: 600; transition: 0.3s; 
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; display: inline-block;
        backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    }
    .btn-back-glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-2px) translateX(-5px); color: #fff; border: 1px solid rgba(255,255,255,0.4); }
    
    .btn-journal { border-bottom: 2px solid rgba(156, 39, 176, 0.4); }
    .btn-comments { border-bottom: 2px solid rgba(33, 150, 243, 0.4); }
    
    .btn:hover { 
        transform: translateY(-2px) scale(1.02); 
        color: #000; 
        background: rgba(255, 255, 255, 0.6);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        border: 1px solid rgba(0,0,0,0.15); 
    }

    .btn-like {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 5px;
        transition: transform 0.2s, filter 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .heart-icon {
        width: 28px;
        height: 28px;
        fill: transparent;
        stroke: #ff4757;
        stroke-width: 2;
        transition: fill 0.3s, stroke 0.3s, transform 0.3s;
    }

    .btn-like.liked .heart-icon {
        fill: #ff4757;
        stroke: #ff4757;
    }

    .btn-like:hover { transform: scale(1.15); }
    .btn-like:active { transform: scale(0.9); }

    /* Toast Notification */
    .toast-glass {
        visibility: hidden;
        min-width: 250px;
        background: rgba(255, 150, 60, 0.9);
        color: white;
        text-align: center;
        border-radius: 50px;
        padding: 16px;
        position: fixed;
        z-index: 2000;
        left: 50%;
        bottom: 30px;
        transform: translateX(-50%);
        font-size: 1rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        border: 1px solid rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(5px);
        opacity: 0;
        transition: opacity 0.5s, bottom 0.5s;
    }

    .toast-glass.show {
        visibility: visible;
        opacity: 1;
        bottom: 50px;
    }

    @@media (max-width: 768px) {
        .real-ticket { flex-direction: column; } .ticket-left { border-radius: 15px 15px 0 0; border-right: none; } .ticket-center-wrapper { display: none; } .ticket-right { border-radius: 0 0 15px 15px; border-left: none; }
    }
</style>

<script>
    function showToast(message) {
        var x = document.getElementById("toast");
        document.getElementById("toastMessage").innerText = message;
        x.className = "toast-glass show";
        setTimeout(function(){ x.className = x.className.replace("show", ""); }, 3000);
    }

    window.toggleLike = function(btn, ticketId) {
        fetch(`/Tickets/ToggleLike?ticketId=${ticketId}`, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if (data.liked) {
                    btn.classList.add('liked');
                    btn.title = "Unlike";
                    showToast("Билетът е добавен в харесани!");
                } else {
                    btn.classList.remove('liked');
                    btn.title = "Like";
                    showToast("Билетът е премахнат от харесани.");
                }
            })
            .catch(err => {
                console.error("Error toggling like:", err);
                showToast("Възникна грешка при харесване.");
            });
    };
</script>
