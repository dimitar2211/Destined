@model Destined.Models.Ticket
@{
    ViewData["Title"] = "Edit Ticket";
    ViewData["FullWidth"] = true;
}

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 40px 20px;">
        <div class="ticket-wrapper">
            <h1 class="page-title">Edit Ticket</h1>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="color-controls">
                    <label>Left part color: <input asp-for="LeftColor" type="color" id="leftColorPicker" /></label>
                    <label>Right part color: <input asp-for="RightColor" type="color" id="rightColorPicker" /></label>
                    <label>Text color: <input asp-for="TextColor" type="color" id="textColorPicker" /></label>
                    <label>Heart color: <input asp-for="HeartColor" type="color" id="heartColorPicker" /></label>
                    <label>Number color: <input asp-for="LikeCountColor" type="color" id="likeCountColorPicker" /></label>
                </div>

                <div class="real-ticket">
                    <div class="ticket-left" id="ticketLeft" style="background:@Model.LeftColor; color:@Model.TextColor;">
                        <h2>
                            <input asp-for="From" class="edit-input location-input" placeholder="From" maxlength="22" />
                            <span class="arrow">➔</span>
                            <input asp-for="To" class="edit-input location-input" placeholder="To" maxlength="22" required />
                        </h2>
                        <p class="date-time">
                            <strong>Date and Time:</strong>
                            <input asp-for="DepartureTime" type="datetime-local" class="edit-input" required />
                            <span asp-validation-for="DepartureTime" class="text-danger"></span>
                        </p>
                        <p class="passengers">
                            <strong>Passengers:</strong>
                            <input asp-for="NumberOfPassengers" type="number" min="1" class="edit-input small-input" required />
                            <span asp-validation-for="NumberOfPassengers" class="text-danger"></span>
                        </p>
                        
                        <div class="dropdown-container">
                            <p style="margin:0;">
                                 <strong>Country:</strong>
                            </p>
                            <input type="text" id="countrySearch" class="dropdown-search edit-input" placeholder="Search country..." autocomplete="off" value="@Model.Country">
                            <input asp-for="Country" type="hidden" id="selectedCountry" />
                            <span asp-validation-for="Country" class="text-danger"></span>
                            <div id="countryList" class="dropdown-list">
                                <!-- Countries will be populated here -->
                            </div>
                        </div>
                        <div class="form-group form-check" style="margin-top: 15px;">
                            <input asp-for="IsPublic" class="form-check-input" type="checkbox" id="IsPublic" />
                            <label asp-for="IsPublic" class="form-check-label">Public ticket?</label>
                            <span asp-validation-for="IsPublic" class="text-danger"></span>
                        </div>
                        <div id="allowCommentsWrapper" style="margin-top: 8px; display: none;">
                            <div class="form-group form-check">
                                <input asp-for="AllowComments" class="form-check-input" type="checkbox" id="AllowComments" />
                                <label asp-for="AllowComments" class="form-check-label" style="font-size: 0.95rem;">Comment section</label>
                            </div>
                        </div>
                    </div>

                    <div class="ticket-center-wrapper">
                        <div class="ticket-center">
                            <div class="perforation"></div>
                        </div>
                    </div>

                    <div class="ticket-right" id="ticketRight" style="background:@Model.RightColor; color:@Model.TextColor;">
                        <div class="barcode"></div>
                        <div class="actions">
                            <div class="preview-like-container" style="display: flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.05); padding: 5px 15px; border-radius: 20px;">
                                <svg viewBox="0 0 24 24" id="previewHeart" style="width: 24px; height: 24px; fill: @Model.HeartColor; stroke: @Model.HeartColor; stroke-width: 2;">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                                <span id="previewLikeCount" style="font-weight: 700; color: @Model.LikeCountColor;">1</span>
                            </div>
                            <button type="submit" class="btn btn-edit">Save</button>
                            <a asp-action="Index" class="btn btn-delete">Cancel</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const maxLength = 22;
            const inputs = document.querySelectorAll('input[asp-for="From"], input[asp-for="To"]');

            inputs.forEach(input => {
                input.addEventListener('input', () => {
                    if (input.value.length > maxLength) {
                        input.value = input.value.slice(0, maxLength);
                    }
                });
            });

            // Country Dropdown Logic
            const countries = [
                // Europe
                "Albania","Andorra","Austria","Belarus","Belgium","Bosnia and Herzegovina","Bulgaria",
                "Vatican City","United Kingdom","Germany","Greece","Denmark","Estonia","Ireland",
                "Iceland","Spain","Italy","Cyprus","Latvia","Lithuania","Liechtenstein","Luxembourg",
                "Malta","Moldova","Monaco","Netherlands","Norway","Poland","Portugal",
                "Romania","San Marino","North Macedonia","Slovakia","Slovenia","Serbia",
                "Ukraine","Hungary","Finland","France","Croatia","Montenegro","Czech Republic",
                "Switzerland","Sweden","Russia","Kosovo",

                // Asia
                "Afghanistan","Armenia","Azerbaijan","Bangladesh","Bahrain","Brunei","Bhutan",
                "Vietnam","Georgia","Israel","India","Indonesia","Iraq","Iran","Jordan",
                "Kazakhstan","Cambodia","Qatar","Kyrgyzstan","China","Kuwait","Laos","Lebanon",
                "Malaysia","Maldives","Mongolia","Myanmar","Nepal","UAE","Oman","Pakistan",
                "Saudi Arabia","North Korea","Singapore","Syria","Tajikistan","Thailand",
                "Turkmenistan","Turkey","Uzbekistan","Philippines","Sri Lanka","South Korea",
                "Japan","Palestine","Timor-Leste","Yemen",

                // Africa
                "Algeria","Angola","Benin","Botswana","Burkina Faso","Burundi","Gabon","Gambia",
                "Ghana","Guinea","Guinea-Bissau","Djibouti","Egypt","Equatorial Guinea",
                "Eritrea","Eswatini","Ethiopia","Zambia","Zimbabwe","Cape Verde","Cameroon",
                "Kenya","Comoros","Congo","DR Congo","Ivory Coast","Lesotho","Liberia",
                "Libya","Madagascar","Malawi","Mali","Morocco","Mauritania","Mauritius",
                "Mozambique","Namibia","Niger","Nigeria","Rwanda","Sao Tome and Principe",
                "Seychelles","Senegal","Sierra Leone","Somalia","Sudan","South Sudan","Tanzania",
                "Togo","Tunisia","Uganda","Central African Republic","Chad","South Africa",

                // North and Central America
                "Antigua and Barbuda","Bahamas","Barbados","Belize","Guatemala","Dominica",
                "Dominican Republic","Canada","Costa Rica","Cuba","Mexico","Nicaragua",
                "Panama","El Salvador","USA","Saint Kitts and Nevis","Saint Lucia",
                "Saint Vincent and the Grenadines","Trinidad and Tobago","Haiti","Honduras","Jamaica",
                "Grenada",

                // South America
                "Argentina","Bolivia","Brazil","Venezuela","Guyana","Colombia","Paraguay",
                "Peru","Suriname","Uruguay","Chile","Ecuador",

                // Oceania
                "Australia","Vanuatu","Kiribati","Marshall Islands","Micronesia","Nauru",
                "New Zealand","Palau","Papua New Guinea","Samoa","Solomon Islands",
                "Tonga","Tuvalu","Fiji"
            ]; 

            const searchInput = document.getElementById('countrySearch');
            const countryList = document.getElementById('countryList');
            const hiddenInput = document.getElementById('selectedCountry');

            // Move to body
            document.body.appendChild(countryList);

            function updateDropdownPosition() {
                const rect = searchInput.getBoundingClientRect();
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
                
                countryList.style.top = (rect.bottom + scrollTop) + 'px';
                countryList.style.left = (rect.left + scrollLeft) + 'px';
                countryList.style.width = rect.width + 'px';
            }

            function populateList(filter = "") {
                countryList.innerHTML = '';
                const filtered = countries.filter(c => c.toLowerCase().includes(filter.toLowerCase()));
                
                // Show all if filter is empty
                let showList = filter === "" ? countries : filtered;

                if (showList.length === 0) {
                    const noResult = document.createElement('div');
                    noResult.className = 'dropdown-item';
                    noResult.textContent = 'No results';
                    
                    noResult.style.color = '#999';
                    noResult.style.cursor = 'default';
                    countryList.appendChild(noResult);
                    return;
                }

                showList.forEach(country => {
                    const item = document.createElement('div');
                    item.className = 'dropdown-item';
                    item.textContent = country;
                    item.addEventListener('click', () => {
                        searchInput.value = country;
                        hiddenInput.value = country;
                        countryList.style.display = 'none';
                    });
                    countryList.appendChild(item);
                });
            }

            searchInput.addEventListener('input', () => {
                populateList(searchInput.value);
                countryList.style.display = 'block';
                updateDropdownPosition();
            });

            searchInput.addEventListener('focus', () => {
                populateList(searchInput.value);
                countryList.style.display = 'block';
                updateDropdownPosition();
            });

            window.addEventListener('resize', () => {
                if (countryList.style.display === 'block') updateDropdownPosition();
            });
            window.addEventListener('scroll', () => {
                 if (countryList.style.display === 'block') updateDropdownPosition();
            }, true);

            document.addEventListener('click', (e) => {
                if (!searchInput.contains(e.target) && !countryList.contains(e.target)) {
                    countryList.style.display = 'none';
                }
            });

            const leftPicker = document.getElementById('leftColorPicker');
            const rightPicker = document.getElementById('rightColorPicker');
            const textPicker = document.getElementById('textColorPicker');
            const heartPicker = document.getElementById('heartColorPicker');
            const likeCountPicker = document.getElementById('likeCountColorPicker');

            const ticketLeft = document.getElementById('ticketLeft');
            const ticketRight = document.getElementById('ticketRight');

            const arrow = ticketLeft.querySelector('.arrow');
            const dateTimeLabel = ticketLeft.querySelector('.date-time strong');
            const passengersLabel = ticketLeft.querySelector('.passengers strong');
            
            const previewHeart = document.getElementById('previewHeart');
            const previewLikeCountText = document.getElementById('previewLikeCount');

            const buttonTextColor = "#ffffff";

            let currentTextColor = textPicker.value;
            let currentLeftColor = leftPicker.value;
            let currentRightColor = rightPicker.value;
            let currentHeartColor = heartPicker.value;
            let currentLikeCountColor = likeCountPicker.value;

            function applyTextColor() {
                const leftInputs = ticketLeft.querySelectorAll('input.edit-input');
                const leftStrongTags = ticketLeft.querySelectorAll('strong');
                const leftLabels = ticketLeft.querySelectorAll('.form-check-label');
                
                const leftTextElements = [...leftInputs, arrow, dateTimeLabel, passengersLabel, ...leftStrongTags, ...leftLabels];
                leftTextElements.forEach(el => {
                    el.style.transition = "none";
                    el.style.color = currentTextColor;
                    if (el.tagName === 'INPUT') {
                        el.style.borderColor = currentTextColor;
                        el.style.setProperty('--placeholder-color', currentTextColor);
                    }
                });

                const rightTextElements = ticketRight.querySelectorAll('*:not(.serial-number):not(.actions)');
                rightTextElements.forEach(el => {
                    if (el.tagName !== 'BUTTON' && el.tagName !== 'A' && el.tagName !== 'INPUT') {
                        el.style.transition = "none";
                        el.style.color = currentTextColor;
                    }
                });

                if (previewHeart) {
                    previewHeart.style.fill = currentHeartColor;
                    previewHeart.style.stroke = currentHeartColor;
                }
                if (previewLikeCountText) {
                    previewLikeCountText.style.color = currentLikeCountColor;
                }

                ticketRight.querySelectorAll('.actions button, .actions a').forEach(btn => {
                    btn.style.transition = "none";
                    btn.style.color = buttonTextColor;
                });
            }

            leftPicker.addEventListener('input', () => {
                currentLeftColor = leftPicker.value;
                ticketLeft.style.backgroundColor = currentLeftColor;
                applyTextColor();
            });

            rightPicker.addEventListener('input', () => {
                currentRightColor = rightPicker.value;
                ticketRight.style.backgroundColor = currentRightColor;
                applyTextColor();
            });

            textPicker.addEventListener('input', () => {
                currentTextColor = textPicker.value;
                applyTextColor();
            });

            heartPicker.addEventListener('input', () => {
                currentHeartColor = heartPicker.value;
                applyTextColor();
            });

            likeCountPicker.addEventListener('input', () => {
                currentLikeCountColor = likeCountPicker.value;
                applyTextColor();
            });

            ticketLeft.style.backgroundColor = currentLeftColor;
            ticketRight.style.backgroundColor = currentRightColor;
            applyTextColor();

            // --- Comment section checkbox visibility ---
            const isPublicCb = document.getElementById('IsPublic');
            const allowCommentsWrapper = document.getElementById('allowCommentsWrapper');
            const allowCommentsCb = document.getElementById('AllowComments');

            function updateCommentsVisibility() {
                if (isPublicCb.checked) {
                    allowCommentsWrapper.style.display = 'block';
                } else {
                    allowCommentsWrapper.style.display = 'none';
                    allowCommentsCb.checked = false;
                }
            }

            isPublicCb.addEventListener('change', updateCommentsVisibility);
            updateCommentsVisibility(); // apply on page load
        });
    </script>
}

<style>
    .ticket-wrapper {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .page-title {
        text-align: center;
        font-size: 2.5rem;
        margin-bottom: 30px;
        color: #fff; /* White for dark themes */
        font-weight: 700;
        letter-spacing: 1.2px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }
    
    .color-controls {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        display: flex;
        justify-content: center;
        gap: 20px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .color-controls label {
        margin-right: 0;
        font-weight: 600;
        color: white;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .real-ticket {
        display: flex;
        background: linear-gradient(145deg, #fafafa, #e6e6e6);
        border-radius: 15px;
        margin-bottom: 30px;
        filter: drop-shadow(0 10px 10px rgba(0,0,0,0.15));
        cursor: default;
        transition: transform 0.3s ease, filter 0.3s ease;
        border: 1.5px solid #bbb;
        position: relative;
        font-weight: 600;
        user-select: none;
        
        -webkit-mask: 
            radial-gradient(circle at center top, transparent 15px, black 15.5px) top center / 100% 51% no-repeat,
            radial-gradient(circle at center bottom, transparent 15px, black 15.5px) bottom center / 100% 51% no-repeat;
        mask: 
            radial-gradient(circle at center top, transparent 15px, black 15.5px) top center / 100% 51% no-repeat,
            radial-gradient(circle at center bottom, transparent 15px, black 15.5px) bottom center / 100% 51% no-repeat;
    }

    .ticket-left, .ticket-right {
        padding: 25px 30px;
        flex: 1;
        position: relative;
        z-index: 10;
    }

    .ticket-left {
        background: #e0f2f1;
        border-right: 1.5px dashed #999;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-radius: 15px 0 0 15px; /* Radius fix */
    }

    /* Custom Dropdown Styles */
    .dropdown-container {
        position: relative;
        width: 100%;
        margin-bottom: 10px;
        margin-top: 10px;
    }

    .dropdown-search {
        width: 100%;
        margin-bottom: 5px;
        background: transparent;
        border: none;
        border-bottom: 1.5px dashed #004d40;
        color: #004d40;
        font-weight: 600;
        font-size: 1.1rem;
        padding: 6px 4px;
    }

    .dropdown-search::placeholder {
        color: #00796b88;
    }

    .dropdown-search:focus {
        outline: none;
        border-color: #4caf50;
    }

    .dropdown-list {
        position: absolute;
        background: white;
        border: 1px solid #ccc;
        border-radius: 4px;
        max-height: 220px;
        overflow-y: auto;
        z-index: 10000;
        display: none;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .dropdown-item {
        padding: 8px 12px;
        cursor: pointer;
        transition: background 0.2s;
        color: #333; /* Ensure text is visible in dropdown */
        text-shadow: none; /* No shadow in dropdown */
    }

    .dropdown-item:hover {
        background: #e0f2f1;
        color: #00796b;
    }


        .ticket-left h2 {
            font-size: 2rem;
            margin-bottom: 12px;
            color: #00796b;
            text-shadow: 0 1px 1px #a0d4cf;
            letter-spacing: 1.2px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ticket-left p {
            font-size: 1.1rem;
            color: #004d40;
            margin: 6px 0;
            display: flex;
            flex-direction: column;
        }

        .ticket-left h2 .arrow {
            font-size: 2rem;
            transition: color 0.3s ease;
        }

    .edit-input {
        background: transparent;
        border: none;
        border-bottom: 1.5px dashed #004d40;
        color: #004d40;
        font-weight: 600;
        font-size: 1.1rem;
        padding: 6px 4px;
        transition: border-color 0.3s ease, color 0.3s ease;
        max-width: 100%;
    }

        .edit-input:focus {
            outline: none;
            border-color: #4caf50;
        }

    .location-input {
        width: 100%;
    }

    .small-input {
        max-width: 150px;
        font-size: 1.1rem;
    }



    .ticket-center-wrapper {
        width: 30px;
        overflow: hidden;
        position: relative;
    }

    .ticket-center {
        width: 30px;
        height: 100%;
        background: repeating-linear-gradient(to bottom, transparent, transparent 8px, #999 8px, #999 10px);
        position: relative;
    }
    
    /* Notches removed */

    .ticket-right {
        background: #fff;
        box-shadow: inset 0 4px 10px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border-left: 1.5px dashed #999;
        border-radius: 0 15px 15px 0; /* Radius fix */
    }

    .barcode {
        width: 100%;
        height: 60px;
        background: repeating-linear-gradient(to right, #000, #000 3px, #fff 3px, #fff 6px, #000 6px, #000 9px, #fff 9px, #fff 12px, #000 12px, #000 15px, #fff 15px, #fff 18px);
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.25);
        margin-bottom: 18px;
    }

    .serial-number {
        font-size: 0.9rem;
        font-family: 'Courier New', Courier, monospace;
        color: #666;
        margin-bottom: 15px;
        text-align: center;
        user-select: text;
    }

    .actions {
        display: flex;
        justify-content: space-around;
        padding-bottom: 10px;
    }

    .btn {
        padding: 8px 16px; 
        border-radius: 20px; 
        text-decoration: none; 
        font-size: 0.95rem; 
        font-weight: 600; 
        cursor: pointer; 
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        border: 1px solid rgba(0,0,0,0.1); 
        color: #333; 
        display: inline-block; 
        text-align: center;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    
    .btn:hover { 
        transform: translateY(-2px) scale(1.02); 
        color: #000; 
        background: rgba(255, 255, 255, 0.6);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        border: 1px solid rgba(0,0,0,0.15); 
    }

    .btn-edit { border-bottom: 2px solid rgba(255, 152, 0, 0.4); } 
    .btn-delete { border-bottom: 2px solid rgba(244, 67, 54, 0.4); } 
</style>
