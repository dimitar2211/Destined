@model IEnumerable<Destined.Models.BlockedUser>

@{
    ViewData["Title"] = "Блокирани Потребители";
    ViewData["FullWidth"] = true;
    var blockedDisplayNames = ViewBag.BlockedDisplayNames as Dictionary<string, string>;
    var blockedPhotos = ViewBag.BlockedPhotos as Dictionary<string, string>;
}

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 40px 20px;">
        <div class="friends-wrapper">
            <h1 class="page-title">Блокирани <span class="gradient-text">Потребители</span></h1>

            <div class="actions-bar d-flex justify-content-center mb-4">
                <a asp-action="Index" class="btn-secondary-glass me-2">⬅ Обратно към Приятели</a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-2 text-center" style="background: rgba(40,167,69,0.2); color: #fff; border: 1px solid rgba(40,167,69,0.5); border-radius: 15px;">@TempData["Success"]</div>
            }

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
                @foreach (var block in Model)
                {
                    <div class="col">
                        <div class="friend-card h-100">
                            <div class="card-body d-flex flex-column h-100 justify-content-between">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="profile-pic-container me-3">
                                        @if (blockedPhotos != null && blockedPhotos.ContainsKey(block.BlockedId) && !string.IsNullOrEmpty(blockedPhotos[block.BlockedId]))
                                        {
                                            <img src="@blockedPhotos[block.BlockedId]" alt="Profile Picture" class="profile-pic-small" />
                                        }
                                        else
                                        {
                                            <div class="profile-pic-placeholder-small">
                                                @(blockedDisplayNames?[block.BlockedId]?.Substring(0, 1).ToUpper() ?? "?")
                                            </div>
                                        }
                                    </div>
                                    <h4 class="card-title text-white mb-0 flex-grow-1">@blockedDisplayNames?[block.BlockedId]</h4>
                                    <form asp-action="Unblock" method="post" class="ms-2">
                                        <input type="hidden" name="friendId" value="@block.BlockedId" />
                                        <button type="submit" class="btn-primary-glow" style="padding: 5px 15px; font-size: 0.85rem;">
                                            Отблокирай
                                        </button>
                                    </form>
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem;">
                                    Блокиран на: @block.CreatedAt.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="no-friends-card">
                    <p>Нямате блокирани потребители.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .friends-wrapper { max-width: 1100px; margin: 0 auto; color: white; }
    .page-title { font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 2rem; color: #fff; }
    .gradient-text { background: linear-gradient(to right, #ff416c, #ff4b2b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .btn-primary-glow, .btn-secondary-glass { 
        padding: 10px 20px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: 0.3s; 
        display: inline-block; border: none; cursor: pointer;
    }
    .btn-primary-glow { background: linear-gradient(45deg, #ff416c, #ff4b2b); color: white; box-shadow: 0 0 15px rgba(255, 65, 108, 0.5); }
    .btn-primary-glow:hover { transform: translateY(-3px); box-shadow: 0 0 25px rgba(255, 65, 108, 0.8); color: white; }
    .btn-secondary-glass { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; }
    .btn-secondary-glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-3px); color: white; border: 1px solid rgba(255,255,255,0.4); }

    .friend-card {
        background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 15px; padding: 15px; transition: transform 0.3s ease;
    }
    .friend-card:hover { transform: translateY(-5px); border-color: rgba(255, 65, 108, 0.5); }

    .profile-pic-container { width: 45px; height: 45px; flex-shrink: 0; }
    .profile-pic-small { width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.2); }
    .profile-pic-placeholder-small { 
        width: 45px; height: 45px; border-radius: 50%; background: linear-gradient(45deg, #4f46e5, #9333ea); 
        display: flex; align-items: center; justify-content: center; font-weight: 700; color: white; border: 2px solid rgba(255,255,255,0.2); 
    }

    .no-friends-card { text-align: center; padding: 50px; color: #cbd5e1; font-size: 1.2rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 2px dashed rgba(255,255,255,0.2); }
</style>
