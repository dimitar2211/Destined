@model IEnumerable<Destined.Models.Friendship>

@{
    ViewData["Title"] = "Моите Приятели";
    ViewData["FullWidth"] = true;
    var friendCode = ViewBag.FriendCode as string;
    var displayUsername = ViewBag.DisplayUsername as string;
    var friendDisplayUsernames = ViewBag.FriendDisplayUsernames as Dictionary<string, string>;
}

@Html.AntiForgeryToken()

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 40px 20px;">
        <div class="friends-wrapper">
            <h1 class="page-title">Моите <span class="gradient-text">Приятели</span></h1>

            <div class="actions-bar d-flex justify-content-center mb-4">
                <a asp-action="Pending" class="btn-secondary-glass me-2 text-warning border-warning">Изпратени покани</a>
                <a asp-action="Received" class="btn-secondary-glass ms-2 text-info border-info">Получени покани</a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-2 text-center" style="background: rgba(40,167,69,0.2); color: #fff; border: 1px solid rgba(40,167,69,0.5); border-radius: 15px;">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-2 text-center" style="background: rgba(220,53,69,0.2); color: #fff; border: 1px solid rgba(220,53,69,0.5); border-radius: 15px;">@TempData["Error"]</div>
            }

            <div class="glass-card mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title text-white">Твоята Информация</h5>
                    <p class="mb-2 text-light">
                        <strong style="color: #a0d4cf;">Потребителско име:</strong> @displayUsername <br />
                        <strong style="color: #a0d4cf;">Твоят Код:</strong> <span class="badge" style="background: linear-gradient(45deg, #3b82f6, #8b5cf6); font-size: 1.1em; padding: 8px 12px; border-radius: 10px;">@friendCode</span>
                    </p>
                    <small class="text-muted" style="color: rgba(255,255,255,0.7) !important;">Сподели своето Потребителско име и Код, за да могат другите да те добавят!</small>
                </div>
            </div>

            <div class="glass-card mb-5">
                <div class="card-body">
                    <h5 class="card-title text-center text-white mb-4">Добави Приятел</h5>
                    <form asp-action="Search" method="post" class="row gx-3 gy-3 align-items-center justify-content-center">
                        <div class="col-sm-4">
                            <label class="visually-hidden" for="username">Потребителско име</label>
                            <input type="text" class="form-control glass-input" id="username" name="username" placeholder="Потребителско име" required>
                        </div>
                        <div class="col-sm-4">
                            <label class="visually-hidden" for="friendCode">Код</label>
                            <input type="text" class="form-control glass-input" id="friendCode" name="friendCode" placeholder="6-Символен Код" maxlength="6" required>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn-primary-glow">Изпрати Поканата</button>
                        </div>
                    </form>
                </div>
            </div>

            <h3 class="text-center text-white mb-4">Списък с приятели</h3>
            @if (!Model.Any())
            {
                <div class="no-friends-card">
                    <p>Все още нямаш приятели. Използвай търсачката по-горе, за да добавиш някого!</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
                    @foreach (var friendship in Model)
                    {
                        <div class="col">
                            <div class="friend-card h-100">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h4 class="card-title text-white mb-0">@friendDisplayUsernames?[friendship.FriendId]</h4>
                                        <form asp-action="Remove" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да премахнете този приятел?');">
                                            <input type="hidden" name="friendId" value="@friendship.FriendId" />
                                            <button type="submit" class="btn-icon-danger" title="Премахни">
                                                🗑️
                                            </button>
                                        </form>
                                    </div>
                                    
                                    <hr style="border-color: rgba(255,255,255,0.2);" />

                                    <div class="mt-auto">
                                        <label class="form-label text-light mb-2" style="font-size: 0.9em;">Кои мои билети вижда този приятел (Моето споделяне):</label>
                                        <form asp-action="UpdateSharing" method="post" class="d-flex gx-2 mb-4">
                                            <input type="hidden" name="friendId" value="@friendship.FriendId" />
                                            <select name="setting" class="form-select form-select-sm glass-input me-2" style="max-width: 150px;">
                                                <option value="All" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.All)" style="color: black;">Всички билети</option>
                                                <option value="PublicOnly" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.PublicOnly)" style="color: black;">Само публични</option>
                                                <option value="PrivateOnly" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.PrivateOnly)" style="color: black;">Само частни</option>
                                                <option value="None" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.None)" style="color: black;">Нищо</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm" style="background: rgba(255,255,255,0.2); color: white; border-radius: 8px;">Запази</button>
                                        </form>

                                        <div class="d-flex flex-column gap-2 mt-3">
                                            <a asp-controller="Tickets" asp-action="FriendTickets" asp-route-friendId="@friendship.FriendId" class="btn-secondary-glass w-100 text-center py-2">🎟️ Виж Билетите</a>
                                            <a asp-controller="Tickets" asp-action="FriendMap" asp-route-friendId="@friendship.FriendId" class="btn-primary-glow w-100 text-center py-2" style="font-size: 0.95rem;">🗺️ Карта на приключенията</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .friends-wrapper { max-width: 1100px; margin: 0 auto; color: white; }
    .page-title { font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 2rem; color: #fff; }
    .gradient-text { background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Buttons */
    .btn-primary-glow, .btn-secondary-glass { 
        padding: 10px 20px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: 0.3s; 
        display: inline-block; border: none; cursor: pointer;
    }
    .btn-primary-glow { background: linear-gradient(45deg, #3b82f6, #8b5cf6); color: white; box-shadow: 0 0 15px rgba(59, 130, 246, 0.5); }
    .btn-primary-glow:hover { transform: translateY(-3px); box-shadow: 0 0 25px rgba(59, 130, 246, 0.8); color: white; }
    .btn-secondary-glass { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; }
    .btn-secondary-glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-3px); color: white; border: 1px solid rgba(255,255,255,0.4); }

    .btn-icon-danger {
        background: rgba(244, 67, 54, 0.1); border: 1px solid rgba(244, 67, 54, 0.3); border-radius: 50%;
        width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; transition: 0.3s; font-size: 1.1rem;
    }
    .btn-icon-danger:hover { background: rgba(244, 67, 54, 0.8); transform: scale(1.1); }

    /* Glass Cards */
    .glass-card {
        background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); overflow: hidden;
    }
    .friend-card {
        background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 15px; padding: 5px; transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .friend-card:hover { transform: translateY(-5px); border-color: rgba(76, 175, 80, 0.5); box-shadow: 0 10px 25px rgba(0,0,0,0.3); }

    .no-friends-card { text-align: center; padding: 50px; color: #cbd5e1; font-size: 1.2rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 2px dashed rgba(255,255,255,0.2); }

    /* Inputs */
    .glass-input {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white; border-radius: 12px; padding: 12px 15px;
    }
    .glass-input:focus {
        background: rgba(255, 255, 255, 0.15);
        border-color: #3b82f6;
        color: white; box-shadow: 0 0 10px rgba(59, 130, 246, 0.3);
    }
    .glass-input::placeholder { color: rgba(255,255,255,0.6); }
</style>
