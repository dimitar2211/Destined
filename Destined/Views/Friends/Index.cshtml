@model IEnumerable<Destined.Models.Friendship>

@{
    ViewData["Title"] = "Моите Приятели";
    ViewData["FullWidth"] = true;
    var friendCode = ViewBag.FriendCode as string;
    var displayUsername = ViewBag.DisplayUsername as string;
    var friendDisplayUsernames = ViewBag.FriendDisplayUsernames as Dictionary<string, string>;
    var adminUserIds = ViewBag.AdminUserIds as List<string> ?? new List<string>();
}

@Html.AntiForgeryToken()

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 40px 20px;">
        <div class="friends-wrapper">
            <h1 class="page-title">Моите <span class="gradient-text">Приятели</span></h1>

            <div class="actions-bar d-flex justify-content-center mb-4">
                <a asp-action="Pending" class="btn-secondary-glass me-2 text-warning border-warning">Изпратени покани</a>
                <a asp-action="Received" class="btn-secondary-glass ms-2 text-info border-info">Получени покани</a>
                @if (ViewBag.ShowBlockedLink == true)
                {
                    <a asp-action="Blocked" class="btn-secondary-glass ms-2 text-danger border-danger">Блокирани потребители</a>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-2 text-center" style="background: rgba(40,167,69,0.2); color: #fff; border: 1px solid rgba(40,167,69,0.5); border-radius: 15px;">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-2 text-center" style="background: rgba(220,53,69,0.2); color: #fff; border: 1px solid rgba(220,53,69,0.5); border-radius: 15px;">@TempData["Error"]</div>
            }

            <div class="glass-card mb-4 text-center">
                <div class="card-body">
                    <h5 class="card-title text-white">Твоята Информация</h5>
                    <p class="mb-2 text-light">
                        <strong style="color: #a0d4cf;">Потребителско име:</strong> @displayUsername <br />
                        <strong style="color: #a0d4cf;">Твоят Код:</strong> <span class="badge" style="background: linear-gradient(45deg, #3b82f6, #8b5cf6); font-size: 1.1em; padding: 8px 12px; border-radius: 10px;">@friendCode</span>
                    </p>
                    <small class="text-muted" style="color: rgba(255,255,255,0.7) !important;">Сподели своето Потребителско име и Код, за да могат другите да те добавят!</small>
                </div>
            </div>

            <div class="glass-card mb-5">
                <div class="card-body">
                    <h5 class="card-title text-center text-white mb-4">Добави Приятел</h5>
                    <form asp-action="Search" method="post" class="row gx-3 gy-3 align-items-center justify-content-center">
                        <div class="col-sm-4">
                            <label class="visually-hidden" for="username">Потребителско име</label>
                            <input type="text" class="form-control glass-input" id="username" name="username" placeholder="Потребителско име" required>
                        </div>
                        <div class="col-sm-4">
                            <label class="visually-hidden" for="friendCode">Код</label>
                            <input type="text" class="form-control glass-input" id="friendCode" name="friendCode" placeholder="6-Символен Код" maxlength="6" required>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn-primary-glow">Изпрати Поканата</button>
                        </div>
                    </form>
                </div>
            </div>

            <h3 class="text-center text-white mb-4">Списък с приятели</h3>
            @if (!Model.Any())
            {
                <div class="no-friends-card">
                    <p>Все още нямаш приятели. Използвай търсачката по-горе, за да добавиш някого!</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
                    @foreach (var friendship in Model)
                    {
                        <div class="col">
                            <div class="friend-card h-100">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h4 class="card-title text-white mb-0">@friendDisplayUsernames?[friendship.FriendId]</h4>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!adminUserIds.Contains(friendship.FriendId))
                                            {
                                                <form asp-action="Block" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да блокирате този потребител?');">
                                                    <input type="hidden" name="friendId" value="@friendship.FriendId" />
                                                    <button type="submit" class="btn-icon-danger" title="Блокирай" style="background: rgba(255, 107, 107, 0.1); border-color: rgba(255, 107, 107, 0.3);">
                                                        🚫
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="Remove" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да премахнете този приятел?');">
                                                <input type="hidden" name="friendId" value="@friendship.FriendId" />
                                                <button type="submit" class="btn-icon-danger" title="Премахни">
                                                    🗑️
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    
                                    <hr style="border-color: rgba(255,255,255,0.2);" />

                                    <div class="mt-auto">
                                        <label class="form-label text-light mb-2" style="font-size: 0.9em;">Кои мои билети вижда този приятел (Моето споделяне):</label>
                                        <form asp-action="UpdateSharing" method="post" class="d-flex gx-2 mb-4">
                                            <input type="hidden" name="friendId" value="@friendship.FriendId" />
                                            <select name="setting" class="form-select form-select-sm glass-input me-2" style="max-width: 150px;">
                                                <option value="All" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.All)" style="color: black;">Всички билети</option>
                                                <option value="PublicOnly" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.PublicOnly)" style="color: black;">Само публични</option>
                                                <option value="PrivateOnly" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.PrivateOnly)" style="color: black;">Само частни</option>
                                                <option value="None" selected="@(friendship.SharingSetting == Destined.Models.SharingSetting.None)" style="color: black;">Нищо</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm" style="background: rgba(255,255,255,0.2); color: white; border-radius: 8px;">Запази</button>
                                        </form>

                                        <div class="d-flex flex-column gap-2 mt-3">
                                            <a asp-controller="Tickets" asp-action="FriendTickets" asp-route-friendId="@friendship.FriendId" class="btn-secondary-glass w-100 text-center py-2">🎟️ Виж Билетите</a>
                                            <a asp-controller="Tickets" asp-action="FriendMap" asp-route-friendId="@friendship.FriendId" class="btn-primary-glow w-100 text-center py-2" style="font-size: 0.95rem;">🗺️ Карта на приключенията</a>
                                            <button type="button" class="btn-chat-toggle w-100 text-center py-2" onclick="toggleChat('@friendship.FriendId')">💬 Чат</button>
                                        </div>

                                        <div class="chat-container-wrapper mt-3" id="chat-container-@friendship.FriendId" style="display: none;">
                                            <div class="chat-messages" id="messages-@friendship.FriendId">
                                                <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-info" role="status"></div></div>
                                            </div>
                                            <div class="chat-input-area d-flex gap-2 mt-2">
                                                <input type="text" class="form-control glass-input chat-input-field" placeholder="Съобщение..." id="input-@friendship.FriendId" onkeypress="if(event.key === 'Enter') sendMessage('@friendship.FriendId')">
                                                <button class="btn-send-message" onclick="sendMessage('@friendship.FriendId')">➤</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .friends-wrapper { max-width: 1100px; margin: 0 auto; color: white; }
    .page-title { font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 2rem; color: #fff; }
    .gradient-text { background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Buttons */
    .btn-primary-glow, .btn-secondary-glass { 
        padding: 10px 20px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: 0.3s; 
        display: inline-block; border: none; cursor: pointer;
    }
    .btn-primary-glow { background: linear-gradient(45deg, #3b82f6, #8b5cf6); color: white; box-shadow: 0 0 15px rgba(59, 130, 246, 0.5); }
    .btn-primary-glow:hover { transform: translateY(-3px); box-shadow: 0 0 25px rgba(59, 130, 246, 0.8); color: white; }
    .btn-secondary-glass { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; }
    .btn-secondary-glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-3px); color: white; border: 1px solid rgba(255,255,255,0.4); }

    .btn-icon-danger {
        background: rgba(244, 67, 54, 0.1); border: 1px solid rgba(244, 67, 54, 0.3); border-radius: 50%;
        width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; transition: 0.3s; font-size: 1.1rem;
    }
    .btn-icon-danger:hover { background: rgba(244, 67, 54, 0.8); transform: scale(1.1); }

    /* Glass Cards */
    .glass-card {
        background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); overflow: hidden;
    }
    .friend-card {
        background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 15px; padding: 5px; transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .friend-card:hover { transform: translateY(-5px); border-color: rgba(76, 175, 80, 0.5); box-shadow: 0 10px 25px rgba(0,0,0,0.3); }

    .no-friends-card { text-align: center; padding: 50px; color: #cbd5e1; font-size: 1.2rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 2px dashed rgba(255,255,255,0.2); }

    /* Inputs */
    .glass-input {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white; border-radius: 12px; padding: 12px 15px;
    }
    .glass-input:focus {
        background: rgba(255, 255, 255, 0.15);
        border-color: #3b82f6;
        color: white; box-shadow: 0 0 10px rgba(59, 130, 246, 0.3);
    }
    .glass-input::placeholder { color: rgba(255,255,255,0.6); }

    /* Chat Styles */
    .btn-chat-toggle {
        background: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); color: #c4b5fd;
        border-radius: 50px; font-weight: 600; transition: 0.3s; cursor: pointer;
    }
    .btn-chat-toggle:hover { background: rgba(139, 92, 246, 0.3); transform: translateY(-2px); color: white; }

    .chat-container-wrapper {
        background: rgba(0, 0, 0, 0.2); border-radius: 15px; padding: 10px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .chat-messages {
        max-height: 300px; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 8px;
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

    .msg-bubble {
        max-width: 80%; padding: 8px 12px; border-radius: 18px; font-size: 0.9rem; position: relative;
        word-wrap: break-word; transition: 0.2s; cursor: pointer; user-select: none;
    }
    .msg-mine {
        align-self: flex-end; background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: white;
        border-bottom-right-radius: 4px;
    }
    .msg-theirs {
        align-self: flex-start; background: rgba(255, 255, 255, 0.15); color: white;
        border-bottom-left-radius: 4px;
    }
    .msg-like {
        position: absolute; bottom: -8px; font-size: 0.8rem;
        background: white; border-radius: 50%; width: 18px; height: 18px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .msg-mine .msg-like { left: -5px; }
    .msg-theirs .msg-like { right: -5px; }

    .btn-send-message {
        background: #3b82f6; border: none; color: white; border-radius: 10px; width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: center; transition: 0.2s;
    }
    .btn-send-message:hover { background: #2563eb; transform: scale(1.05); }

    .chat-context-menu {
        position: fixed; background: rgba(30, 30, 30, 0.95); backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px; padding: 5px;
        z-index: 1000; display: none; box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }
    .chat-context-menu button {
        display: block; width: 100%; padding: 8px 15px; background: none; border: none;
        color: white; text-align: left; font-size: 0.85rem; border-radius: 5px; cursor: pointer;
    }
    .chat-context-menu button:hover { background: rgba(255, 255, 255, 0.1); }
    .btn-delete-msg { color: #f87171 !important; }
</style>

<div id="chat-menu" class="chat-context-menu">
    <button onclick="editMsgAction()">✏️ Редактирай</button>
    <button class="btn-delete-msg" onclick="deleteMsgAction()">🗑️ Изтрий</button>
</div>

<script>
    let activeMsgId = null;
    let longPressTimer = null;

    function toggleChat(friendId) {
        const container = document.getElementById('chat-container-' + friendId);
        if (container.style.display === 'none') {
            // Close other chats? (Optional, let's keep it simple)
            container.style.display = 'block';
            loadMessages(friendId);
            
            // Start polling if not already started
            if (!container.dataset.polling) {
                container.dataset.polling = setInterval(() => loadMessages(friendId), 5000);
            }
        } else {
            container.style.display = 'none';
            if (container.dataset.polling) {
                clearInterval(parseInt(container.dataset.polling));
                delete container.dataset.polling;
            }
        }
    }

    function loadMessages(friendId) {
        fetch('/Chat/GetMessages?friendId=' + friendId)
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById('messages-' + friendId);
                list.innerHTML = '';
                data.forEach(m => {
                    const div = document.createElement('div');
                    div.className = 'msg-bubble ' + (m.isMine ? 'msg-mine' : 'msg-theirs');
                    div.innerHTML = m.content;
                    div.dataset.id = m.id;
                    div.dataset.mine = m.isMine;
                    
                    if (m.isLiked) {
                        const heart = document.createElement('span');
                        heart.className = 'msg-like';
                        heart.innerHTML = '❤️';
                        div.appendChild(heart);
                    }

                    // Double click to like (only for theirs)
                    div.ondblclick = () => {
                        if (!m.isMine) {
                            toggleLike(m.id, friendId);
                        }
                    };

                    // Long press for mine
                    div.onmousedown = (e) => startLongPress(e, m.id, m.isMine, m.content);
                    div.ontouchstart = (e) => startLongPress(e, m.id, m.isMine, m.content);
                    div.onmouseup = clearLongPress;
                    div.onmouseleave = clearLongPress;
                    div.ontouchend = clearLongPress;

                    list.appendChild(div);
                });
                list.scrollTop = list.scrollHeight;
            });
    }

    function sendMessage(friendId) {
        const input = document.getElementById('input-' + friendId);
        const content = input.value.trim();
        if (!content) return;

        fetch('/Chat/Send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'friendId=' + friendId + '&content=' + encodeURIComponent(content)
        }).then(r => r.json()).then(res => {
            if (res.success) {
                input.value = '';
                loadMessages(friendId);
            }
        });
    }

    function toggleLike(msgId, friendId) {
        fetch('/Chat/ToggleLike', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'messageId=' + msgId
        }).then(() => loadMessages(friendId));
    }

    function startLongPress(e, msgId, isMine, content) {
        if (!isMine) return;
        
        clearLongPress();
        activeMsgId = msgId;
        activeMsgContent = content;

        longPressTimer = setTimeout(() => {
            const menu = document.getElementById('chat-menu');
            menu.style.display = 'block';
            menu.style.left = (e.clientX || e.touches[0].clientX) + 'px';
            menu.style.top = (e.clientY || e.touches[0].clientY) + 'px';
        }, 500);
    }

    function clearLongPress() {
        if (longPressTimer) clearTimeout(longPressTimer);
    }

    document.addEventListener('click', (e) => {
        if (!e.target.closest('.chat-context-menu') && !e.target.closest('.msg-bubble')) {
            document.getElementById('chat-menu').style.display = 'none';
        }
    });

    function deleteMsgAction() {
        if (!activeMsgId) return;
        if (!confirm('Сигурни ли сте, че искате да изтриете това съобщение?')) return;

        fetch('/Chat/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'messageId=' + activeMsgId
        }).then(() => {
            document.getElementById('chat-menu').style.display = 'none';
            // Find which friend's chat this was and reload it
            // Simple way: reload all visible chats
            document.querySelectorAll('.chat-container-wrapper').forEach(c => {
                if (c.style.display !== 'none') {
                    const fid = c.id.replace('chat-container-', '');
                    loadMessages(fid);
                }
            });
        });
    }

    function editMsgAction() {
        if (!activeMsgId) return;
        const newContent = prompt('Редактирай съобщението:', activeMsgContent);
        if (newContent === null || newContent === activeMsgContent) return;

        fetch('/Chat/Edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'messageId=' + activeMsgId + '&content=' + encodeURIComponent(newContent)
        }).then(() => {
            document.getElementById('chat-menu').style.display = 'none';
            document.querySelectorAll('.chat-container-wrapper').forEach(c => {
                if (c.style.display !== 'none') {
                    const fid = c.id.replace('chat-container-', '');
                    loadMessages(fid);
                }
            });
        });
    }
</script>
