@model IEnumerable<Destined.Models.FriendRequest>

@{
    ViewData["Title"] = "Получени Покани";
    ViewData["FullWidth"] = true;
    var senderDisplayNames = ViewBag.SenderDisplayNames as Dictionary<string, string>;
}

<div style="position: relative; min-height: 100vh; overflow-x: hidden;">
    <partial name="_ThemeBackground" />

    <div id="page-content" style="position: relative; z-index: 10; padding: 100px 20px 40px 20px;">
        <div class="requests-wrapper">
            <h1 class="page-title"><span class="gradient-text">Получени</span> Покани</h1>
            <div class="actions-bar mb-4 text-center">
                <a asp-action="Index" class="btn-back-glass">⬅ Назад към приятели</a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success text-center" style="background: rgba(40,167,69,0.2); color: #fff; border: 1px solid rgba(40,167,69,0.5); border-radius: 15px;">@TempData["Success"]</div>
            }

            @if (!Model.Any())
            {
                <div class="no-requests-card">
                    <p>Нямате нови покани за приятелство.</p>
                </div>
            }
            else
            {
                <div class="glass-list">
                    @foreach (var request in Model)
                    {
                        <div class="glass-list-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong style="font-size: 1.2rem; display: block; margin-bottom: 5px;">@senderDisplayNames?[request.SenderId]</strong>
                                <small style="color: rgba(255,255,255,0.6);">Иска да сте приятели</small><br />
                                <small style="color: rgba(255,255,255,0.4);">Изпратена на: @request.CreatedAt.ToString("g")</small>
                            </div>
                            <div class="d-flex gap-2">
                                <form asp-action="Accept" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <button type="submit" class="btn-success-glass">Приеми</button>
                                </form>
                                <form asp-action="Decline" method="post" class="m-0" onsubmit="return confirm('Отхвърли тази покана за приятелство?');">
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <button type="submit" class="btn-danger-glass">Отхвърли</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .requests-wrapper { max-width: 800px; margin: 0 auto; color: white; }
    .page-title { font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 2rem; color: #fff; }
    .gradient-text { background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .btn-back-glass { 
        padding: 10px 24px; border-radius: 50px; text-decoration: none; font-weight: 600; transition: 0.3s; 
        background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; display: inline-block;
        backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    }
    .btn-back-glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-2px) translateX(-5px); color: white; border: 1px solid rgba(255,255,255,0.4); }

    .btn-success-glass {
        padding: 8px 16px; border-radius: 20px; border: 1px solid rgba(76, 175, 80, 0.4);
        background: rgba(76, 175, 80, 0.15); color: white; font-weight: 600; cursor: pointer; transition: 0.3s;
    }
    .btn-success-glass:hover { background: rgba(76, 175, 80, 0.4); transform: scale(1.05); }

    .btn-danger-glass {
        padding: 8px 16px; border-radius: 20px; border: 1px solid rgba(244, 67, 54, 0.4);
        background: rgba(244, 67, 54, 0.15); color: white; font-weight: 600; cursor: pointer; transition: 0.3s;
    }
    .btn-danger-glass:hover { background: rgba(244, 67, 54, 0.4); transform: scale(1.05); }

    .no-requests-card { text-align: center; padding: 50px; color: #cbd5e1; font-size: 1.2rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 2px dashed rgba(255,255,255,0.2); }

    .glass-list {
        background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px; overflow: hidden;
    }
    .glass-list-item {
        padding: 20px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        transition: background 0.3s;
    }
    .glass-list-item:hover { background: rgba(255, 255, 255, 0.1); }
    .glass-list-item:last-child { border-bottom: none; }
</style>
